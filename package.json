{
  "name": "gashapon",
  "version": "0.1.0",
  "description": "Wrap MCP servers as independent CLI binaries",
  "type": "module",
  "bin": {
    "gashapon": "./bin/run.js"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepare": "npx tsc -p tsconfig.json",
    "prepack": "npx tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3",
    "chalk": "^5",
    "open": "^11.0.0",
    "typescript": "^5",
    "yargs-parser": "^21",
    "zod": "^3"
  },
  "devDependencies": {
    "@oclif/test": "^4",
    "@types/node": "^22",
    "@types/yargs-parser": "^21",
    "@vitest/coverage-v8": "^3",
    "tsx": "^4",
    "vitest": "^3"
  },
  "oclif": {
    "bin": "gashapon",
    "dirname": "gashapon",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-not-found"
    ],
    "topicSeparator": " ",
    "topics": {
      "servers": {
        "description": "Manage MCP server configurations"
      }
    }
  },
  "engines": {
    "node": ">=20"
  }
}
